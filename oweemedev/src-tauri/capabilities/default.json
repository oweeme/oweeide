{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-close",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "opener:default",
    "opener:allow-open-url",
    "dialog:default",
    "dialog:allow-open",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "bash",    "cmd": "bash",    "args": true, "sidecar": false },
        { "name": "sh",      "cmd": "sh",      "args": true, "sidecar": false },
        { "name": "zsh",     "cmd": "zsh",     "args": true, "sidecar": false },
        { "name": "python3", "cmd": "python3", "args": true, "sidecar": false },
        { "name": "python",  "cmd": "python",  "args": true, "sidecar": false },
        { "name": "node",    "cmd": "node",    "args": true, "sidecar": false },
        { "name": "php",     "cmd": "php",     "args": true, "sidecar": false },
        { "name": "go",      "cmd": "go",      "args": true, "sidecar": false },
        { "name": "cargo",   "cmd": "cargo",   "args": true, "sidecar": false }
      ]
    }
  ]
}
