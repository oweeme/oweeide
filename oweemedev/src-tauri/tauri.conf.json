{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OweemeIDE",
  "version": "0.1.0",
  "identifier": "com.oweeme.oweemedev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OweemeIDE",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Oweeme Dev",
    "copyright": "© 2025 Oweeme Dev. Todos los derechos reservados.",
    "category": "DeveloperTool",
    "shortDescription": "OweemeIDE — IDE de desarrollo moderno",
    "longDescription": "OweemeIDE es un entorno de desarrollo integrado moderno construido con Tauri y Vue 3. Incluye editor de código, terminal integrada, explorador de archivos, cliente de bases de datos y asistente de IA.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "category": "Development",
      "mimeTypes": []
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Spanish"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "es-ES"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
